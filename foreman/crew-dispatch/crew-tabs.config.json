{
  "workspaceName": "Werkles Aeye Crew",
  "mode": "edge-dispatch-bay",
  "autoSend": false,
  "humanSendGate": true,
  "courier": {
    "script": "scripts/foreman/relay-courier.ps1",
    "cli": "scripts/foreman/relay-courier.mjs",
    "lib": "scripts/foreman/relay-courier-lib.mjs",
    "profileDir": "foreman/.edge-aeye-crew-profile",
