{
  "schemaVersion": "aeye-dispatch-policy/v0.1",
  "description": "Dispatch classification and AUTO_SEND guards for Relay Courier.",
  "heldCousins": {
    "ENDER": {
      "availability": "HELD_ON_SALLY",
      "topologyLock": "foreman/change-capsules/CHANGE_CAPSULE_ENDER_SALLY_RETIRED.json",
      "reason": "Ender@Sally is retired until Sally RAM upgrade and a clearing receipt.",
      "rule": "Do not auto-send, auto-load, generate tests, or create new Ender@Sally packets."
    }
  },
  "classes": {
    "AUTO_SEND": {
      "id": "CLASS_A",
      "label": "AUTO_SEND",
      "description": "Locked-template, low-risk operational sync only.",
      "allowedTemplates": [
        "ROLE_AWARENESS_SYNC",
        "CREW_ROUTING_UPDATE",
        "COCKPIT_STATUS_SYNC",
        "GATE_SUMMARY_SYNC"
      ],
      "allowedCousins": [
        "PETRA",
        "SKYBRO",
        "BEAN",
        "COMPUTER"
      ],
      "requiresFreshHashes": true,
      "requiresHealthyContext": true,
      "maxPacketBytes": 32768,
      "rateLimit": {
        "maxPerCousin": 3,
        "windowMinutes": 10
      }
    },
    "AUTO_LOAD_HUMAN_SEND": {
      "id": "CLASS_B",
      "label": "AUTO_LOAD_HUMAN_SEND",
      "description": "Load into target tab, stop before Send.",
      "defaultForUnclassified": true
    },
    "BLOCKED": {
      "id": "CLASS_C",
      "label": "BLOCKED",
      "description": "Never load or send.",
      "markers": [
        "DO_NOT_SEND",
        "CLASS_C",
        "BLOCKED_PACKET"
      ]
    }
  },
  "blockedContent": {
    "structuralMarkers": [
      "DO_NOT_SEND",
      "NEVER_SEND",
      "CLASS_C_BLOCKED"
    ],
    "filenamePatterns": [
      "\\.env",
      "credentials",
      "secret",
      "token",
      "service-role"
    ],
    "neverLoadPatterns": [
      "sk_live_",
      "sk_test_",
      "service_role",
      "SUPABASE_SERVICE",
      "BEGIN PRIVATE KEY",
      "oauth_token",
      "refresh_token"
    ]
  },
  "secretScan": {
    "primaryDefense": "dispatch_class_and_structural_markers",
    "regexSecondaryOnly": true,
    "regexPatterns": [
      "\\b(?:sk|pk)_(?:live|test)_[A-Za-z0-9]{10,}\\b",
      "\\beyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]+",
      "\\b(?:api[_-]?key|secret|password|token)\\s*[:=]\\s*['\"][^'\"\\s]{8,}"
    ]
  },
  "approvedLockedTemplates": {
    "ROLE_AWARENESS_SYNC": {
      "dispatchClass": "AUTO_SEND",
      "manifest": "foreman/crew-dispatch/LATEST_NETWORK_COMMAND.json",
      "issuerScript": "foreman/crew-dispatch/crew-relay-network-command.mjs"
    },
    "AUTONOMOUS_ROUND_TRIP_TEST": {
      "dispatchClass": "AUTONOMOUS_ROUND_TRIP_TEST",
      "cousins": [
        "ENDER"
      ],
      "status": "HELD_ON_SALLY",
      "topologyLock": "foreman/change-capsules/CHANGE_CAPSULE_ENDER_SALLY_RETIRED.json",
      "explicitTestFlag": "ALLOW_AUTONOMOUS_ROUND_TRIP_SEND",
      "issuerScript": "scripts/foreman/autonomous-round-trip-test.mjs",
      "packetTemplate": "foreman/templates/TO_AUTONOMOUS_ROUND_TRIP_TEST_TEMPLATE.md",
      "pasteBlock": "foreman/handoffs/outbox/ENDER_PASTE_BLOCK.txt",
      "proofManifest": "foreman/crew-dispatch/AUTONOMOUS_ROUND_TRIP_PROOF.json",
      "description": "HELD: Ender@Sally retired until RAM upgrade and clearing receipt. Do not run this harness."
    },
    "AUTONOMOUS_ROUND_TRIP_TEST_SKYBRO": {
      "dispatchClass": "AUTONOMOUS_ROUND_TRIP_TEST",
      "cousins": [
        "SKYBRO"
      ],
      "explicitTestFlag": "ALLOW_AUTONOMOUS_ROUND_TRIP_SEND",
      "issuerScript": "scripts/foreman/autonomous-round-trip-skybro.mjs",
      "packetTemplate": "foreman/templates/TO_AUTONOMOUS_ROUND_TRIP_TEST_TEMPLATE.md",
      "pasteBlock": "foreman/handoffs/outbox/SKYBRO_PASTE_BLOCK.txt",
      "proofManifest": "foreman/crew-dispatch/AUTONOMOUS_ROUND_TRIP_SKYBRO_PROOF.json",
      "description": "SKYBRO round-trip — same path as ENDER proof"
    },
    "HOMEPAGE_REWRITE_DISCOVERY_SMOKE_TEST": {
      "dispatchClass": "AUTONOMOUS_ROUND_TRIP_TEST",
      "cousins": [
        "SKYBRO",
        "COMPUTER"
      ],
      "heldCousins": [
        "ENDER"
      ],
      "topologyLock": "foreman/change-capsules/CHANGE_CAPSULE_ENDER_SALLY_RETIRED.json",
      "explicitTestFlag": "ALLOW_AUTONOMOUS_ROUND_TRIP_SEND",
      "issuerScript": "scripts/foreman/homepage-rewrite-discovery-smoke-test.mjs",
      "packetTemplate": "foreman/templates/TO_HOMEPAGE_REWRITE_DISCOVERY_SMOKE_TEST_TEMPLATE.md",
      "proofManifest": "foreman/crew-dispatch/HOMEPAGE_REWRITE_DISCOVERY_SMOKE_PROOF.json",
      "description": "Homepage discovery smoke with Ender held on Sally; no Ender@Sally packet until RAM upgrade and clearing receipt."
    },
    "WERKLES_HOMEPAGE_DISCOVERY_FULL_CREW": {
      "dispatchClass": "AUTONOMOUS_ROUND_TRIP_TEST",
      "cousins": [
        "SKYBRO",
        "COMPUTER"
      ],
      "heldCousins": [
        "ENDER"
      ],
      "topologyLock": "foreman/change-capsules/CHANGE_CAPSULE_ENDER_SALLY_RETIRED.json",
      "explicitTestFlag": "ALLOW_AUTONOMOUS_ROUND_TRIP_SEND",
      "issuerScript": "scripts/foreman/werkles-homepage-discovery-full-crew.mjs",
      "packetTemplate": "foreman/templates/TO_WERKLES_HOMEPAGE_DISCOVERY_FULL_CREW_TEMPLATE.md",
      "proofManifest": "foreman/crew-dispatch/WERKLES_HOMEPAGE_DISCOVERY_FULL_CREW_PROOF.json",
      "description": "Full crew homepage discovery with Ender held on Sally; no Ender@Sally packet until RAM upgrade and clearing receipt."
    }
  }
}
