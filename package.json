{
  "name": "werkles",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "relay:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/foreman/install-relay-courier.ps1",
    "relay:self-test": "node scripts/foreman/relay-courier.mjs self-test",
    "AUTONOMOUS_ROUND_TRIP_TEST": "node scripts/foreman/autonomous-round-trip-test.mjs --execute",
    "AUTONOMOUS_ROUND_TRIP_SKYBRO": "node scripts/foreman/autonomous-round-trip-skybro.mjs --execute",
    "HOMEPAGE_REWRITE_DISCOVERY_SMOKE_TEST": "node scripts/foreman/homepage-rewrite-discovery-smoke-test.mjs --execute",
    "WERKLES_HOMEPAGE_DISCOVERY_FULL_CREW": "node scripts/foreman/werkles-homepage-discovery-full-crew.mjs --execute",
    "foreman": "node scripts/foreman/foreman-control-server.mjs",
    "gd:list": "node foreman/gd-intent-router/gd-intent-router.mjs list",
    "gd:route": "node foreman/gd-intent-router/gd-intent-router.mjs route",
    "gd:generate": "node foreman/gd-intent-router/gd-intent-router.mjs generate",
    "gd:collect": "node foreman/gd-intent-router/gd-intent-router.mjs collect",
    "gd:synthesize": "node foreman/gd-intent-router/gd-intent-router.mjs synthesize",
    "gd:runs": "node foreman/gd-intent-router/gd-intent-router.mjs runs",
    "gd:thread-refresh": "node foreman/gd-intent-router/gd-intent-router.mjs thread-refresh",
    "gd:gimpdash": "node -e \"require('child_process').execSync('start http://127.0.0.1:4317/#gimpdash',{stdio:'inherit',shell:true})\"",
    "receipt:crawler": "node scripts/foreman/crawler.js",
    "receipt:crawler:self-test": "node scripts/foreman/crawler.js --self-test",
    "relay:command-dash": "node scripts/foreman/command-dash-aeye-relay.mjs",
    "relay:command-dash:intake": "node scripts/foreman/command-dash-relay-intake.mjs --once",
    "relay:command-dash:watch": "node scripts/foreman/command-dash-relay-intake.mjs --watch",
    "relay:command-dash:doctor": "node scripts/foreman/command-dash-relay-doctor.mjs",
    "relay:command-dash:triage": "node scripts/foreman/command-dash-inbox-triage.mjs",
    "relay:command-dash:status": "node scripts/foreman/command-dash-relay-status.mjs",
    "nerdkle:doctor": "node scripts/foreman/nerdkle-doctor.mjs",
    "nerdkle:packet": "node scripts/foreman/nerdkle-execution-packet.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "playwright": "^1.60.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
